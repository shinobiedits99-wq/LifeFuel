    <!-- PWA Service Worker (inline) -->
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(err => console.log('SW registration failed:', err));
            });
        }
    </script>
    <script id="sw-code" type="javascript/worker">
        const CACHE_NAME = 'lifefule-ai-v1';
        const urlsToCache = [
            '/',
            'https://fonts.googleapis.com/css2?family=Inter:opsz@14..32&display=swap',
            'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css',
            'https://cdn.tailwindcss.com',
            'https://cdn.jsdelivr.net/npm/chart.js',
            'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js',
            'https://js.stripe.com/v3/',
            'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2'
        ];
        self.addEventListener('install', event => {
            event.waitUntil(
                caches.open(CACHE_NAME).then(cache => cache.addAll(urlsToCache))
            );
        });
        self.addEventListener('fetch', event => {
            event.respondWith(
                caches.match(event.request).then(response => response || fetch(event.request))
            );
        });
    </script>
    <script>
        // Dynamically create a Blob for the service worker
        (function() {
            const swCode = document.getElementById('sw-code').textContent;
            const blob = new Blob([swCode], { type: 'application/javascript' });
            const swUrl = URL.createObjectURL(blob);
            if ('serviceWorker' in navigator) {
                navigator.serviceWorker.register(swUrl).catch(e => console.log('SW fallback'));
            }
        })();
    </script>

    <!-- Main Application Script -->
    <script>
        (function() {
            // ==================== CONFIGURATION ====================
            const SUPABASE_URL = "https://ypqieapdpixwshhllcut.supabase.co";
            const SUPABASE_ANON_KEY = "sb_publishable_g0i8LwUmbxd1_KZ3HG6vDA_uYBWFHO"; // your existing anon key

            // ==================== SUPABASE CLIENT ====================
            const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

            // ==================== THREE.JS BACKGROUND ====================
            const initThree = () => {
                const container = document.getElementById('canvas-container');
                if (!container) return;

                const scene = new THREE.Scene();
                scene.background = new THREE.Color(0x0a0a0f);

                const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
                camera.position.set(0, 2, 25);

                const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
                renderer.setSize(window.innerWidth, window.innerHeight);
                renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
                container.appendChild(renderer.domElement);

                const ambient = new THREE.AmbientLight(0x404060);
                scene.add(ambient);
                const light1 = new THREE.PointLight(0x8b5cf6, 1.2, 40);
                light1.position.set(8, 6, 15);
                scene.add(light1);
                const light2 = new THREE.PointLight(0x10b981, 0.8, 40);
                light2.position.set(-8, -4, 15);
                scene.add(light2);

                const geometry = new THREE.TorusKnotGeometry(3.8, 1.1, 200, 16);
                const material = new THREE.MeshStandardMaterial({
                    color: 0x8b5cf6,
                    emissive: 0x2a1b4a,
                    wireframe: true,
                    transparent: true,
                    opacity: 0.25
                });
                const knot = new THREE.Mesh(geometry, material);
                scene.add(knot);

                const particlesGeo = new THREE.BufferGeometry();
                const particlesCount = 2500;
                const positions = new Float32Array(particlesCount * 3);
                for (let i = 0; i < particlesCount * 3; i += 3) {
                    positions[i] = (Math.random() - 0.5) * 90;
                    positions[i+1] = (Math.random() - 0.5) * 90;
                    positions[i+2] = (Math.random() - 0.5) * 90;
                }
                particlesGeo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
                const particlesMat = new THREE.PointsMaterial({
                    size: 0.12,
                    color: 0x8b5cf6,
                    transparent: true,
                    opacity: 0.5,
                    blending: THREE.AdditiveBlending
                });
                const particles = new THREE.Points(particlesGeo, particlesMat);
                scene.add(particles);

                function animate() {
                    requestAnimationFrame(animate);
                    knot.rotation.x += 0.0008;
                    knot.rotation.y += 0.0015;
                    particles.rotation.y += 0.0002;
                    renderer.render(scene, camera);
                }
                animate();

                window.addEventListener('resize', () => {
                    camera.aspect = window.innerWidth / window.innerHeight;
                    camera.updateProjectionMatrix();
                    renderer.setSize(window.innerWidth, window.innerHeight);
                });
            };

            // ==================== APP STATE ====================
            let user = null;
            let meals = [];
            let calorieChart = null;
            const PRO_KEY = 'lifefule_pro';
            let isPro = localStorage.getItem(PRO_KEY) === 'true';
            const MAX_FREE_MEALS = 5;

            // DOM elements
            const authForms = document.getElementById('auth-forms');
            const loggedInView = document.getElementById('logged-in-view');
            const authText = document.getElementById('auth-text');
            const userEmailSpan = document.getElementById('user-email');
            const emailInput = document.getElementById('email');
            const passwordInput = document.getElementById('password');
            const signupBtn = document.getElementById('signup-btn');
            const loginBtn = document.getElementById('login-btn');
            const logoutBtn = document.getElementById('logout-btn');
            const saveMealBtn = document.getElementById('save-meal-btn');
            const foodInput = document.getElementById('food');
            const caloriesInput = document.getElementById('calories');
            const mealsList = document.getElementById('meals');
            const mealLimitMsg = document.getElementById('meal-limit-msg');
            const mealCountSpan = document.getElementById('meal-count');
            const limitUpgrade = document.getElementById('limit-upgrade');
            const proBtn = document.getElementById('pro-btn');
            const modal = document.getElementById('payment-modal');
            const closeModal = document.getElementById('close-modal');
            const mockPayBtn = document.getElementById('mock-pay-btn');

            // AI elements
            const aiInsightDiv = document.getElementById('ai-insight');
            const refreshAiBtn = document.getElementById('refresh-ai');

            // Stats elements
            const aiScore = document.getElementById('ai-score');
            const calorieBurn = document.getElementById('calorie-burn');
            const waterIntake = document.getElementById('water-intake');
            const sleepHours = document.getElementById('sleep-hours');

            // ==================== UI UPDATE FUNCTIONS ====================
            function updateAuthUI() {
                if (user) {
                    authForms.classList.add('hidden');
                    loggedInView.classList.remove('hidden');
                    userEmailSpan.textContent = user.email;
                    authText.textContent = 'Dashboard';
                    loadMeals();
                } else {
                    authForms.classList.remove('hidden');
                    loggedInView.classList.add('hidden');
                    authText.textContent = 'Sign In';
                    mealsList.innerHTML = '<li class="text-white/40 text-center">Please log in to see meals.</li>';
                    if (calorieChart) calorieChart.destroy();
                    aiInsightDiv.innerHTML = '<p class="text-white/40">Log in to get AI insights.</p>';
                }
            }

            function updateProUI() {
                if (isPro) {
                    mealLimitMsg.classList.add('hidden');
                } else {
                    mealLimitMsg.classList.remove('hidden');
                    updateMealCount();
                }
            }

            function updateMealCount() {
                if (!isPro && user) {
                    mealCountSpan.textContent = meals.length;
                    if (meals.length >= MAX_FREE_MEALS) {
                        saveMealBtn.disabled = true;
                        saveMealBtn.classList.add('opacity-50', 'cursor-not-allowed');
                    } else {
                        saveMealBtn.disabled = false;
                        saveMealBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                    }
                } else {
                    saveMealBtn.disabled = false;
                    saveMealBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                }
            }

            // ==================== SUPABASE AUTH ====================
            async function signUp() {
                const email = emailInput.value.trim();
                const password = passwordInput.value.trim();
                if (!email || !password) return alert('Please enter email and password');
                const { data, error } = await supabase.auth.signUp({ email, password });
                if (error) alert('Signup error: ' + error.message);
                else alert('Signup successful! Check your email for confirmation.');
            }

            async function logIn() {
                const email = emailInput.value.trim();
                const password = passwordInput.value.trim();
                if (!email || !password) return alert('Please enter email and password');
                const { data, error } = await supabase.auth.signInWithPassword({ email, password });
                if (error) alert('Login error: ' + error.message);
                else {
                    user = data.user;
                    updateAuthUI();
                }
            }

            async function logOut() {
                await supabase.auth.signOut();
                user = null;
                meals = [];
                updateAuthUI();
            }

            // ==================== MEAL FUNCTIONS ====================
            async function loadMeals() {
                if (!user) return;
                const { data, error } = await supabase
                    .from('meals')
                    .select('*')
                    .eq('user_id', user.id)
                    .order('created_at', { ascending: false });
                if (error) {
                    console.error('Load meals error:', error);
                    mealsList.innerHTML = '<li class="text-red-400 text-center">Error loading meals.</li>';
                    return;
                }
                meals = data || [];
                renderMeals();
                updateMealCount();
                drawChart();
                generateMockAIInsight(); // Auto AI after meal load
            }

            async function addMeal() {
                if (!user) return alert('Please log in first.');
                if (!isPro && meals.length >= MAX_FREE_MEALS) {
                    showPaymentModal();
                    return;
                }
                const food = foodInput.value.trim();
                const calories = parseInt(caloriesInput.value.trim());
                if (!food || isNaN(calories)) return alert('Please enter food name and calories.');

                const { data, error } = await supabase
                    .from('meals')
                    .insert([{ food_name: food, calories: calories, user_id: user.id }])
                    .select();
                if (error) {
                    alert('Error saving meal: ' + error.message);
                } else {
                    foodInput.value = '';
                    caloriesInput.value = '';
                    loadMeals(); // reload to include new meal
                }
            }

            function renderMeals() {
                if (!meals.length) {
                    mealsList.innerHTML = '<li class="text-white/40 text-center">No meals yet. Add one!</li>';
                    return;
                }
                let html = '';
                meals.slice(0, 10).forEach(meal => {
                    html += `<li class="flex justify-between items-center bg-white/5 p-2 rounded-lg"><span>${meal.food_name}</span><span class="text-emerald-400">${meal.calories} cal</span></li>`;
                });
                mealsList.innerHTML = html;
            }

            function drawChart() {
                const ctx = document.getElementById('calorieChart').getContext('2d');
                if (calorieChart) calorieChart.destroy();

                const last7 = meals.slice(0, 7).reverse();
                const labels = last7.map(m => m.food_name.substring(0, 10) + (m.food_name.length > 10 ? '…' : ''));
                const data = last7.map(m => m.calories);

                calorieChart = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels.length ? labels : ['No Data'],
                        datasets: [{
                            label: 'Calories',
                            data: data.length ? data : [0],
                            backgroundColor: '#8b5cf6',
                            borderRadius: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#aaa' } },
                            x: { grid: { display: false }, ticks: { color: '#aaa' } }
                        }
                    }
                });
            }

            // ==================== MOCK AI INSIGHTS (No API Key Needed) ====================
            function generateMockAIInsight() {
                if (!user) {
                    aiInsightDiv.innerHTML = '<p class="text-white/40">Log in to get AI insights.</p>';
                    return;
                }
                if (meals.length === 0) {
                    aiInsightDiv.innerHTML = '<p class="text-white/60">Add some meals, and I’ll give you personalized health tips!</p>';
                    return;
                }

                aiInsightDiv.innerHTML = '<p class="animate-pulse">🧠 AI is thinking...</p>';

                // Simulate AI delay
                setTimeout(() => {
                    const totalCalories = meals.reduce((sum, m) => sum + m.calories, 0);
                    const mealCount = meals.length;
                    const avgCalories = Math.round(totalCalories / mealCount);

                    // Generate a contextual insight
                    let insight = '';
                    if (totalCalories > 2000) {
                        insight = "You're doing great! Maybe add some veggies to balance.";
                    } else if (totalCalories < 1500) {
                        insight = "You're under your calorie goal – consider a healthy snack.";
                    } else {
                        insight = "Great job staying on track! Keep it up.";
                    }

                    // Add some variety based on meal names
                    const hasProtein = meals.some(m => /chicken|fish|egg|tofu|meat/.test(m.food_name.toLowerCase()));
                    if (hasProtein) {
                        insight += " Nice protein intake!";
                    } else {
                        insight += " Remember to include protein for muscle health.";
                    }

                    aiInsightDiv.innerHTML = `<p class="text-white/80">${insight}</p>`;
                }, 800);
            }

            // ==================== PRO MODAL ====================
            function showPaymentModal() {
                modal.classList.add('show');
            }

            if (closeModal) {
                closeModal.addEventListener('click', () => modal.classList.remove('show'));
            }
            if (mockPayBtn) {
                mockPayBtn.addEventListener('click', () => {
                    isPro = true;
                    localStorage.setItem(PRO_KEY, 'true');
                    updateProUI();
                    modal.classList.remove('show');
                    alert('🎉 Welcome to Pro! You now have unlimited meals and AI insights.');
                    if (user) loadMeals(); // refresh to enable save button
                });
            }
            if (proBtn) proBtn.addEventListener('click', showPaymentModal);
            if (limitUpgrade) limitUpgrade.addEventListener('click', showPaymentModal);

            // ==================== EVENT LISTENERS ====================
            signupBtn.addEventListener('click', signUp);
            loginBtn.addEventListener('click', logIn);
            logoutBtn.addEventListener('click', logOut);
            saveMealBtn.addEventListener('click', addMeal);
            if (refreshAiBtn) refreshAiBtn.addEventListener('click', generateMockAIInsight);

            // Auth state change listener
            supabase.auth.onAuthStateChange((event, session) => {
                if (session) {
                    user = session.user;
                } else {
                    user = null;
                }
                updateAuthUI();
            });

            // Check existing session on load
            (async () => {
                const { data: { session } } = await supabase.auth.getSession();
                if (session) user = session.user;
                updateAuthUI();
            })();

            // ==================== MOCK STATS REFRESH ====================
            function refreshMockStats() {
                aiScore.textContent = 85 + Math.floor(Math.random() * 12);
                calorieBurn.textContent = 1200 + Math.floor(Math.random() * 200);
                waterIntake.textContent = (2 + Math.random() * 0.8).toFixed(1) + 'L';
                sleepHours.textContent = (7 + Math.random()).toFixed(1) + 'h';
            }

            // ==================== AUTOMATION ====================
            // Auto‑refresh AI insight every 30 seconds if user is logged in
            setInterval(() => {
                if (user) generateMockAIInsight();
            }, 30000);

            // ==================== INIT ====================
            document.addEventListener('DOMContentLoaded', () => {
                initThree();
                updateProUI();
                refreshMockStats();
                setInterval(refreshMockStats, 45000); // update stats periodically

                // Install prompt for PWA
                let deferredPrompt;
                window.addEventListener('beforeinstallprompt', (e) => {
                    e.preventDefault();
                    deferredPrompt = e;
                    document.getElementById('install-hint').addEventListener('click', () => {
                        deferredPrompt.prompt();
                    });
                });
            });
        })();
    </script>
</body>
</html>
